# Server
PORT=2000

# MongoDB connection string
MONGO_URI="mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority"

# JWT secret 
ACCESS_TOKEN="<long-random-string>"

# Default profile picture URL used on signup
default_profile_pic="https://example.com/default_profile_avatar.png"

# Email (Gmail App Password or SMTP). Pick ONE approach:
# - Gmail App Password:
MAIL_USER="you@gmail.com"
MAIL_PASS="<gmail-app-password>"

# - Or OAuth2 (optional)
OAUTH_CLIENTID=""
OAUTH_CLIENT_SECRET=""
OAUTH_REFRESH_TOKEN=""

# Redis. Upstash example:
# REDIS_URL="rediss://default:<password>@<endpoint>.upstash.io:<port>"
REDIS_URL=""
REDIS_CACHE_TTL_SECONDS=30